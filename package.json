{
	"name": "svelte-tools",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"scrape:inazuma-vr:players": "tsx src/scripts/inazuma-eleven-vr/players.ts",
		"scrape:inazuma-vr:hissatsu-movies": "tsx src/scripts/inazuma-eleven-vr/hissatsu-movies.ts",
		"scrape:digimon-story-ts:digimons": "tsx src/scripts/digimon-story-ts/digimons.ts",
		"scrape:digimon-story-ts:download-icons": "tsx src/scripts/digimon-story-ts/download-icons.ts",
		"scrape:pmd-blue:download-icons": "tsx src/scripts/pmd-blue/download-icons.ts"
	},
	"devDependencies": {
