---
const {name, min, max, value} = Astro.props
---

<label for={name} class="sr-only"></label>
<input type="range" id={name} name={name} min={min} max={max} value={value} step="1"
       class="bg-violet-200 h-3 w-full cursor-pointer appearance-none rounded-full">

<style>
    input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        background-color: #8b5cf6;
        width: 24px;
        height: 24px;
        border-radius: 100%;
        box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
    }

    input[type="range"]::-moz-range-thumb {
        -webkit-appearance: none;
        appearance: none;
        background-color: #8b5cf6;
        width: 24px;
        height: 24px;
        border-radius: 100%;
        box-shadow: 0px 0px 3px 2px #8b5cf6;

    }
</style>